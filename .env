# JARVIS AI Assistant Configuration

# General Settings
JARVIS_NAME=JARVIS
JARVIS_VERSION=1.0.0
DEBUG=False

# Speech Settings
SPEECH_RATE=150
SPEECH_VOLUME=1.0
SPEECH_VOICE_INDEX=0

# Web Interface Settings
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=False
SECRET_KEY=change-this-secret-key-in-production

# Database
DATABASE_PATH=jarvis.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=jarvis.log
